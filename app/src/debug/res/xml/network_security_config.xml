<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug network security configuration.
    Allows cleartext (plain HTTP) traffic to the Firebase emulator host (10.0.2.2)
    so that Auth, Firestore, and Storage emulators work on Android 9+.
    This file overrides the main/res/xml/network_security_config.xml for debug builds only.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <!-- Trust user-installed CAs in debug builds for easier local HTTPS testing -->
            <certificates src="user" />
        </trust-anchors>
    </base-config>
    <!-- Allow cleartext HTTP to the Android emulator loopback host used by Firebase emulators -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>

