<?xml version="1.0" encoding="utf-8"?>
<!--
    Production network security configuration.
    Cleartext traffic is disabled by default for all domains.
    Debug builds override this file to allow cleartext to the Firebase emulator host.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

