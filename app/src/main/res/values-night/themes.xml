<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (dark). -->
    <style name="Base.Theme.AndroidApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/brand_primary_light</item>
        <item name="colorOnPrimary">@color/brand_primary_dark</item>
        <item name="colorPrimaryContainer">@color/brand_primary_dark</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary_light</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/brand_secondary_light</item>
        <item name="colorOnSecondary">@color/brand_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_dark</item>
        <item name="colorOnSecondaryContainer">@color/brand_secondary_light</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/brand_tertiary</item>
        <item name="colorOnTertiary">@color/brand_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/brand_tertiary_container_dark</item>
        <item name="colorOnTertiaryContainer">@color/brand_on_tertiary_container_dark</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container_dark</item>
        <item name="colorOnErrorContainer">@color/on_error_container_dark</item>

        <!-- Background / Surface -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>
        <item name="colorOutline">@color/outline_dark</item>
    </style>
</resources>
